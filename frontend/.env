# =========================================================================
# DEPLOYMENT CONFIG
# =========================================================================
# For production this app is served by the backend from the same origin.
# The frontend will use a relative API path (`/api/tasks`) by default so
# you do NOT need to set an instance public IP when building/deploying.
#
# For local development you can uncomment and use the localhost API URL:
# VITE_API_URL=http://localhost:5000/api/tasks

# Leave unset in production to use the relative path.
